# Playdate build output. Reproducible from source with:
#   pdc source builds/LastLine.pdx
# Keeping compiled .pdx bundles out of the repo avoids binary diff noise and the
# ambiguity of several bundles sitting side by side.
builds/
*.pdx/

# Compiled Lua sources
luac.out

# luarocks build files
*.src.rock
*.zip
*.tar.gz

# Object files
*.o
*.os
*.ko
*.obj
*.elf

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo
*.def
*.exp

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

